    "description": "Ways of expressing equivocal/indeterminate status",
    "variations": {
      "equivocal": 0.30,
      "indeterminate": 0.25,
      "inconclusive": 0.20,
      "failed_QC": 0.10,
      "borderline": 0.08,
      "insufficient_for_analysis": 0.07
    },
    "realizations": {
      "equivocal": "equivocal",
      "indeterminate": "indeterminate",
      "inconclusive": "inconclusive",
      "failed_QC": "failed QC",
