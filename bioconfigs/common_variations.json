  "not_tested_phrases": {
    "$schema_type": "weighted_variations",
    "description": "Ways of expressing that testing did not occur or could not be completed",
    "variations": {
      "not_tested": 0.35,
      "testing_pending": 0.20,
      "not_performed": 0.15,
      "insufficient_sample": 0.15,
      "quantity_not_sufficient": 0.05,
