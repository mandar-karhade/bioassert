  "test_methods": {
    "$schema_type": "weighted_variations",
    "description": "Testing methodologies that may appear alongside results. This is the canonical source of method realizations; biomarker-level preferred_methods overrides WEIGHTS only, not realizations.",
    "variations": {
      "unspecified": 0.38,
      "NGS": 0.22,
      "IHC": 0.10,
      "FISH": 0.08,
      "PCR": 0.06,
      "liquid_biopsy": 0.05,
      "ctDNA": 0.04,
      "Sanger": 0.02,
      "ddPCR": 0.02,
      "RNA_seq": 0.02,
      "comprehensive_genomic_profiling": 0.01
    },
    "realizations": {
      "unspecified": "",
      "NGS": "NGS",
      "IHC": "IHC",
      "FISH": "FISH",
      "PCR": "PCR",
      "liquid_biopsy": "liquid biopsy",
      "ctDNA": "ctDNA",
