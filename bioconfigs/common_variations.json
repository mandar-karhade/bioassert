  "positive_shorthand": {
    "$schema_type": "weighted_variations",
    "description": "L2 compact positive surface tokens used in shorthand sentence frames (tabular result lists, terse pathology addenda). Weights reflect observed term-frequency in clinical text not patient prevalence.",
    "variations": {
      "plus": 0.35,
      "parens_plus": 0.20,
      "pos": 0.20,
      "positive": 0.10,
      "plus_slash": 0.05,
      "detected": 0.05,
      "pos_dot": 0.05
    },
    "realizations": {
      "plus": "+",
      "parens_plus": "(+)",
      "pos": "pos",
      "positive": "positive",
      "plus_slash": "+/+",
      "detected": "detected",
      "pos_dot": "pos."
    }
  },

  "negation_shorthand": {
    "$schema_type": "weighted_variations",
    "description": "L2 compact negative surface tokens used in shorthand sentence frames. Weights reflect observed term-frequency in clinical text not patient prevalence.",
    "variations": {
      "minus": 0.30,
      "parens_minus": 0.20,
      "neg": 0.20,
      "wt_abbrev": 0.10,
      "negative": 0.10,
      "not_detected": 0.05,
      "neg_dot": 0.05
    },
    "realizations": {
      "minus": "-",
      "parens_minus": "(-)",
      "neg": "neg",
      "wt_abbrev": "WT",
      "negative": "negative",
      "not_detected": "not detected",
      "neg_dot": "neg."
    }
  },

