  "method_attribution_frames": {
    "$schema_type": "weighted_variations",
    "description": "How test methods are linked to results. Used when test_method != 'unspecified'. Realizations contain {method} and/or {result} placeholders filled at render time.",
    "variations": {
      "by_METHOD": 0.35,
      "on_METHOD": 0.20,
      "METHOD_colon_result": 0.15,
      "per_METHOD": 0.10,
      "METHOD_revealed": 0.10,
      "via_METHOD": 0.05,
      "METHOD_confirmed": 0.05
    },
    "realizations": {
      "by_METHOD": "by {method}",
      "on_METHOD": "on {method}",
      "METHOD_colon_result": "{method}: {result}",
      "per_METHOD": "per {method}",
      "METHOD_revealed": "{method} revealed",
      "via_METHOD": "via {method}",
      "METHOD_confirmed": "{method} confirmed"
