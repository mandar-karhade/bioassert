{
  "$schema_version": "1.1",
  "description": "Surface-form variations shared across all biomarkers. Weights are probabilities (floats summing to 1.0 per category, validated at load time). Slot placeholders in grammar templates reference these categories.",
  "_changelog": [
    "v1.1: Added $schema_type discriminator to distinguish weighted_variations from post_process_transformations (technical_noise)"
  ],
  "notes": [
    "All weight distributions sum to 1.0 within tolerance 0.001",
    "Weights reflect best-estimate clinical corpus priors, not strict measurements",
    "Calibrate against real-text held-out set in Phase 7",
    "Bold/italic/underline in pathology reports are not surface variations — they're a formatting layer"
  ],

  "assertion_verbs": {
    "$schema_type": "weighted_variations",
    "description": "Verbs linking biomarker to its status in affirmative contexts",
    "variations": {
      "was": 0.18,
      "is": 0.12,
      "tested": 0.10,
      "testing_showed": 0.08,
      "showed": 0.08,
      "revealed": 0.07,
      "demonstrated": 0.05,
      "identified_as": 0.05,
      "detected_as": 0.04,
      "reported_as": 0.04,
      "returned": 0.04,
      "came_back": 0.03,
      "no_verb_colon": 0.08,
      "no_verb_dash": 0.04
    },
    "realizations": {
      "was": "was",
      "is": "is",
      "tested": "tested",
      "testing_showed": "testing showed",
      "showed": "showed",
      "revealed": "revealed",
      "demonstrated": "demonstrated",
      "identified_as": "identified as",
      "detected_as": "detected as",
      "reported_as": "reported as",
      "returned": "returned",
      "came_back": "came back",
      "no_verb_colon": ":",
      "no_verb_dash": "—"
    }
  },

  "negation_phrases": {
    "$schema_type": "weighted_variations",
    "description": "Ways of expressing negative status (status=negative)",
    "variations": {
      "negative": 0.28,
      "not_detected": 0.18,
      "no_evidence_of": 0.10,
      "wild_type": 0.10,
      "wt_abbrev": 0.06,
      "absent": 0.04,
      "no_mutation_detected": 0.08,
      "no_X_identified": 0.05,
      "none_detected": 0.03,
      "unremarkable": 0.02,
      "minus_sign": 0.03,
      "neg_abbrev": 0.03
    },
    "realizations": {
      "negative": "negative",
      "not_detected": "not detected",
      "no_evidence_of": "no evidence of",
      "wild_type": "wild-type",
      "wt_abbrev": "WT",
      "absent": "absent",
      "no_mutation_detected": "no mutation detected",
      "no_X_identified": "no {gene} alteration identified",
      "none_detected": "none detected",
      "unremarkable": "unremarkable",
      "minus_sign": "(-)",
      "neg_abbrev": "neg"
    }
  },

  "positive_phrases": {
    "$schema_type": "weighted_variations",
    "description": "Ways of expressing positive status (status=positive)",
    "variations": {
      "positive": 0.25,
      "detected": 0.18,
      "mutated": 0.10,
      "identified": 0.08,
      "present": 0.06,
      "found": 0.06,
      "observed": 0.04,
      "plus_sign": 0.04,
      "pos_abbrev": 0.04,
      "mutation_present": 0.05,
      "alteration_detected": 0.05,
      "confirmed": 0.05
    },
    "realizations": {
      "positive": "positive",
      "detected": "detected",
      "mutated": "mutated",
      "identified": "identified",
      "present": "present",
      "found": "found",
      "observed": "observed",
      "plus_sign": "(+)",
      "pos_abbrev": "pos",
      "mutation_present": "mutation present",
      "alteration_detected": "alteration detected",
      "confirmed": "confirmed"
    }
  },

  "equivocal_phrases": {
