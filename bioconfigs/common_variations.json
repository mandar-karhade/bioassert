  "list_connectors": {
    "$schema_type": "weighted_variations",
    "description": "How multiple biomarkers are joined in compound sentences",
    "variations": {
      "comma_and": 0.30,
      "oxford_and": 0.20,
      "semicolon": 0.20,
      "comma_only": 0.15,
      "newline": 0.08,
      "and_only": 0.07
    },
    "realizations": {
      "comma_and": ", and",
      "oxford_and": ", and",
      "semicolon": ";",
      "comma_only": ",",
      "newline": "\n",
      "and_only": " and"
    }
  },

  "technical_noise": {
    "$schema_type": "post_process_transformations",
    "description": "Surface-level typographic variations applied probabilistically during post-processing, AFTER all semantic composition. Each sub-dict is its own weighted distribution summing to 1.0. Loader validates per sub-dict, not on the outer object.",
    "whitespace": {
      "description": "Whitespace variation applied at token boundaries",
      "distribution": {
        "single_space": 0.85,
        "double_space": 0.05,
        "tab": 0.03,
        "newline_mid_sentence": 0.04,
        "no_space_after_punct": 0.03
      }
    },
    "case_variation": {
      "description": "Case transformation applied to entire sentence",
      "distribution": {
        "canonical": 0.92,
        "all_lowercase": 0.04,
        "all_uppercase": 0.02,
        "title_case": 0.02
      }
    },
    "hyphenation_gene_names": {
      "description": "Specific to genes whose abbreviations are sometimes hyphenated (EGF-R, HER-2, PD-L1). Applied only to biomarker name renders.",
      "distribution": {
        "canonical": 0.80,
        "hyphenated": 0.12,
        "spaced": 0.05,
        "linebroken": 0.03
      }
    },
    "punctuation_variation": {
      "description": "Punctuation artifacts commonly seen in real clinical text",
      "distribution": {
        "canonical": 0.90,
        "missing_period": 0.05,
        "extra_comma": 0.03,
        "ocr_artifact": 0.02
      }
    },
    "ocr_corruption": {
      "description": "Visually-confusable character swaps (l/1, O/0, S/5, B/8, Z/2, I/l) simulating OCR misreads on scanned clinical documents. Length-preserving; never touches labeled spans.",
      "distribution": {
        "canonical": 0.93,
        "light": 0.05,
        "moderate": 0.02
      }
    },
    "pdf_artifact": {
      "description": "PDF-extraction artifacts: inserts a hyphenated linebreak ('-\\n') inside a non-labeled token to simulate a word broken across a page edge. Adjusts labeled spans to stay anchored.",
      "distribution": {
        "canonical": 0.96,
        "hyphen_linebreak": 0.04
      }
    },
    "abbreviation_inconsistency": {
      "description": "When a rendered record contains two or more labeled mentions of the same canonical gene (e.g., L6 temporal_frame2: 'ERBB2 was positive at diagnosis; ERBB2 was negative post-TKI.'), re-render mention #2+ with an alternate alias drawn from biomarkers.json name_forms.variations, excluding mention #1's surface. Models real pathology-report drift between equivalent abbreviations (ERBB2/HER2/HER-2, PD-L1/PDL1/PD L1). Single-mention records are unaffected.",
      "distribution": {
        "canonical": 0.70,
        "mixed": 0.30
      }
    }
  }
}
